# Copy this to config/env/.env.docker and fill in your values
# Used by infra/docker/docker-compose.yml and infra/scripts/*.sh

# Environment to build: dev | uat | prod
BUILD_ENV=prod

# Port to expose locally (default 80)
PORT=80

# Docker image name (local tag)
IMAGE_NAME=sgx-frontend

# --- ECS / ECR (required for deployment) ---
AWS_REGION=ap-southeast-1
AWS_ACCOUNT_ID=123456789012
ECR_REGISTRY=${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com
ECR_REPO=sgx-frontend

# ECS cluster and service names (one per env)
ECS_CLUSTER=sgx-cluster
ECS_SERVICE_DEV=sgx-frontend-dev
ECS_SERVICE_UAT=sgx-frontend-uat
ECS_SERVICE_PROD=sgx-frontend-prod
